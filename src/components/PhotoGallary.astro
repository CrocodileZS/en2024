---
interface Props {
  images: string[];
}

const { images } = Astro.props as Props;
---

<div class="photo-gallery">
  {images.map((src, index) => (
    <button
      class="photo-card"
      type="button"
      data-full={src}
      aria-label={`Open photo ${index + 1}`}
    >
      <img src={src} alt="" loading="lazy" decoding="async" referrerpolicy="no-referrer" />
    </button>
  ))}
</div>

<dialog class="lightbox" id="lightbox">
  <div class="lightbox-inner">
    <button class="lightbox-close" type="button" aria-label="Close preview">
      ×
    </button>
    <img class="lightbox-image" src="" alt="" />
  </div>
</dialog>

<script>
  const dialog = document.getElementById('lightbox');
  const dialogImage = dialog?.querySelector('.lightbox-image');
  const closeButton = dialog?.querySelector('.lightbox-close');
  const cards = document.querySelectorAll('.photo-card');

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const src = card.getAttribute('data-full');
      if (!dialog || !dialogImage || !src) return;
      dialogImage.setAttribute('src', src);
      dialog.showModal();
    });
  });

  closeButton?.addEventListener('click', () => {
    dialog?.close();
  });

  dialog?.addEventListener('click', (event) => {
    if (event.target === dialog) {
      dialog.close();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && dialog?.open) {
      dialog.close();
    }
  });
</script>

<style>
  .photo-gallery {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 14px;
    margin: 2rem 0;
  }

  .photo-card {
    grid-column: span 4;
    padding: 0;
    margin: 0;
    border: none;
    overflow: hidden;
    border-radius: 18px;
    cursor: zoom-in;
    background: rgba(255, 255, 255, 0.04);
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.08),
      0 1px 3px rgba(0, 0, 0, 0.06);
    transition: transform 0.28s ease, box-shadow 0.28s ease;
  }

  .photo-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 16px 40px rgba(0, 0, 0, 0.14),
      0 4px 10px rgba(0, 0, 0, 0.08);
  }

  .photo-card img {
    width: 100%;
    display: block;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .photo-card:hover img {
    transform: scale(1.03);
  }

  .lightbox {
    padding: 0;
    border: none;
    background: transparent;
    width: 100vw;
    height: 100vh;
    max-width: none;
    max-height: none;
  }

  .lightbox::backdrop {
    background: rgba(0, 0, 0, 0.82);
    backdrop-filter: blur(6px);
  }

  .lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-inner {
    position: relative;
    width: min(92vw, 1400px);
    height: min(88vh, 1000px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-image {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    display: block;
    object-fit: contain;
    border-radius: 18px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.42);
    background: transparent;
  }

  .lightbox-close {
    position: absolute;
    top: -8px;
    right: -8px;
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 999px;
    font-size: 28px;
    line-height: 1;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.18);
    color: white;
    backdrop-filter: blur(8px);
  }

  @media (max-width: 900px) {
    .photo-card {
      grid-column: span 6;
    }
  }

  @media (max-width: 560px) {
    .photo-gallery {
      gap: 10px;
    }

    .photo-card {
      grid-column: span 12;
      border-radius: 14px;
    }

    .lightbox-inner {
      width: 94vw;
      height: 82vh;
    }

    .lightbox-image {
      border-radius: 14px;
    }

    .lightbox-close {
      top: -10px;
      right: 0;
    }
  }
</style>