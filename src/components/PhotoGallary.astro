---
interface Props {
  images: string[];
}

const { images } = Astro.props as Props;

const thumb = (url: string) =>
  `${url}${url.includes('?') ? '&' : '?'}x-oss-process=image/resize,w_900/quality,q_80`;

const full = (url: string) =>
  `${url}${url.includes('?') ? '&' : '?'}x-oss-process=image/resize,w_1600/quality,q_85`;
---

<div class="photo-gallery">
  {images.map((src, index) => (
    <button
      class="photo-card"
      type="button"
      data-full={full(src)}
      aria-label={`Open photo ${index + 1}`}
    >
      <img
        src={thumb(src)}
        alt=""
        loading="lazy"
        decoding="async"
        referrerpolicy="no-referrer"
      />
    </button>
  ))}
</div>

<dialog class="lightbox" id="lightbox">
  <div class="lightbox-inner">
    <button class="lightbox-close" type="button">×</button>
    <div class="lightbox-loading">Loading...</div>
    <img class="lightbox-image" src="" alt="" />
  </div>
</dialog>

<script>
  const dialog = document.getElementById('lightbox');
  const dialogImage = dialog?.querySelector('.lightbox-image');
  const closeButton = dialog?.querySelector('.lightbox-close');
  const loading = dialog?.querySelector('.lightbox-loading');
  const cards = document.querySelectorAll('.photo-card');

  function openImage(src) {
    if (!dialog || !dialogImage || !loading) return;

    dialogImage.removeAttribute('src');
    dialogImage.classList.remove('visible');

    loading.classList.add('visible');

    if (!dialog.open) dialog.showModal();

    const img = new Image();

    img.onload = () => {
      dialogImage.src = src;
      dialogImage.classList.add('visible');
      loading.classList.remove('visible');
    };

    img.src = src;
  }

  cards.forEach(card => {
    card.addEventListener('click', () => {
      openImage(card.dataset.full);
    });
  });

  closeButton?.addEventListener('click', () => dialog.close());

  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && dialog?.open) dialog.close();
  });
</script>

<style>
.photo-gallery{
  display:grid;
  grid-template-columns:repeat(12,1fr);
  gap:14px;
  margin:2rem 0;
}

.photo-card{
  grid-column:span 4;
  padding:0;
  border:none;
  border-radius:18px;
  overflow:hidden;
  cursor:zoom-in;
  background:#00000008;
  transition:transform .25s ease, box-shadow .25s ease;
}

.photo-card:hover{
  transform:translateY(-4px);
  box-shadow:0 10px 30px rgba(0,0,0,.15);
}

.photo-card img{
  width:100%;
  display:block;
  aspect-ratio:4/5;
  object-fit:cover;
}

/* 平板 */
@media (max-width:900px){
  .photo-card{
    grid-column:span 6;
  }
}

/* 手机 */
@media (max-width:560px){

  .photo-gallery{
    gap:6px;
  }

  .photo-card{
    grid-column:span 4;
    border-radius:10px;
  }

  .photo-card img{
    aspect-ratio:1/1;
  }

}

/* lightbox */

.lightbox{
  padding:0;
  border:none;
  width:100vw;
  height:100vh;
  max-width:none;
  max-height:none;
  background:transparent;
}

.lightbox::backdrop{
  background:rgba(0,0,0,.85);
  backdrop-filter:blur(6px);
}

.lightbox[open]{
  display:flex;
  align-items:center;
  justify-content:center;
}

.lightbox-inner{
  position:relative;
  width:min(92vw,1400px);
  height:min(88vh,1000px);
  display:flex;
  align-items:center;
  justify-content:center;
}

.lightbox-image{
  display:none;
  max-width:100%;
  max-height:100%;
  object-fit:contain;
  border-radius:16px;
  box-shadow:0 30px 80px rgba(0,0,0,.45);
}

.lightbox-image.visible{
  display:block;
}

.lightbox-loading{
  display:none;
  color:white;
  font-size:.9rem;
  opacity:.7;
}

.lightbox-loading.visible{
  display:block;
}

.lightbox-close{
  position:absolute;
  top:-8px;
  right:-8px;
  width:44px;
  height:44px;
  border:none;
  border-radius:999px;
  font-size:26px;
  cursor:pointer;
  background:rgba(255,255,255,.2);
  color:white;
}

@media (max-width:560px){

  .lightbox-inner{
    width:96vw;
    height:84vh;
  }

  .lightbox-close{
    width:38px;
    height:38px;
    font-size:22px;
  }

}
</style>